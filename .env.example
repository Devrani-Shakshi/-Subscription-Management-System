# ── Application ──────────────────────────────────────────────────
APP_NAME=SubManager
APP_ENV=development
DEBUG=true

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/submanager
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT / Auth ───────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE-ME-generate-a-64-char-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Seed / Invite ────────────────────────────────────────────────
SEED_SECRET=generate-a-random-seed-secret
FRONTEND_URL=http://localhost:8081
INVITE_EXPIRE_HOURS=48

# ── Rate Limiting ────────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

# ── PayPal Payment Gateway ──────────────────────────────────────
# ⚠️  Get your API keys from: https://developer.paypal.com/
#     Go to: Dashboard → My Apps & Credentials → Create App
PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_CLIENT_SECRET=your-paypal-client-secret-here
PAYPAL_MODE=sandbox
PAYPAL_SUCCESS_URL=http://localhost:8081/payment/success
PAYPAL_CANCEL_URL=http://localhost:8081/payment/cancel

# ── Sentry (optional) ───────────────────────────────────────────
SENTRY_DSN=
